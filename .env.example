# --- Core ---
NODE_ENV=development
PORT=3000

# --- Data stores ---
MONGODB_URI=mongodb://localhost:27017/opc
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Salt used when hashing inbound x-api-key headers (SHA1(salt + key))
OPC_API_KEY_SALT=change-me-in-prod
# Comma-separated list of allowed SHA1 hashes of API keys (hex). Empty = dev-bypass.
OPC_API_KEY_HASHES=

# --- Twitter / X (OAuth2 PKCE) ---
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:3000/oauth/twitter/callback

# --- Scheduler ---
# Set to "true" only on a single instance if you run multiple replicas.
ENABLE_SCHEDULER=true
